{
  // ============================================================================
  // CURSOR IDE SETTINGS FOR CALCULADORA-BMC
  // File location: ~/.config/Cursor/settings.json
  // ============================================================================

  // ============================================================================
  // TERMINAL CONFIGURATION
  // ============================================================================
  
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.profiles.osx": {
    "zsh": {
      "path": "/bin/zsh",
      "args": ["-l"],
      "icon": "terminal",
      "env": {
        "CALCULADORA_BMC_ROOT": "${workspaceFolder}",
        "NODE_ENV": "development",
        "VERCEL_PROJECT_ID": "panelin-bmc"
      }
    }
  },
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.fontFamily": "'Menlo', 'Monaco', 'Courier New'",
  "terminal.integrated.lineHeight": 1.4,
  "terminal.integrated.scrollback": 5000,
  "terminal.integrated.inheritEnv": true,

  // ============================================================================
  // EDITOR & FORMATTING
  // ============================================================================

  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.rulers": [80, 120],
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.wordWrap": "on",
  "editor.renderWhitespace": "trailing",
  "editor.trimAutoWhitespace": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.fixAll.prettier": "explicit"
  },

  // ============================================================================
  // LANGUAGE SPECIFIC SETTINGS
  // ============================================================================

  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },

  // ============================================================================
  // REACT & JSX SPECIFIC
  // ============================================================================

  "javascript.renameShadowedVariables": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "react.useSnippets": true,

  // ============================================================================
  // FILE ASSOCIATIONS
  // ============================================================================

  "files.associations": {
    "*.jsx": "javascriptreact",
    "*.tsx": "typescriptreact",
    ".env.local": "properties",
    ".env.example": "properties"
  },
  "files.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/.next": true,
    "**/dist": true,
    "**/.DS_Store": true,
    "**/coverage": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/node_modules/*/**": true,
    "**/.next/**": true,
    "**/dist/**": true
  },

  // ============================================================================
  // GIT INTEGRATION
  // ============================================================================

  "git.ignoreLimitWarning": true,
  "git.autorefresh": true,
  "git.confirmSync": false,
  "git.countBadge": "auto",
  "git.decorations.enabled": true,

  // ============================================================================
  // EXPLORER & SIDEBAR
  // ============================================================================

  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": true,
  "explorer.openEditors.visible": 5,
  "explorer.compactFolders": true,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.jsx": "${basename}.module.css, ${basename}.module.scss, ${basename}.stories.js",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, vercel.json",
    ".env.local": ".env.*.local, .env.example"
  },

  // ============================================================================
  // SEARCH & FIND
  // ============================================================================

  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.next": true,
    "**/coverage": true,
    "**/.git": true
  },
  "search.followSymlinks": false,
  "search.useRipgrep": true,

  // ============================================================================
  // DEBUGGING
  // ============================================================================

  "debug.console.fontSize": 12,
  "debug.console.lineHeight": 1.3,
  "debug.toolBarLocation": "floating",

  // ============================================================================
  // EXTENSIONS & ECOSYSTEM
  // ============================================================================

  "extensions.recommendations": [
    "esbenp.prettier-vscode",
    "dbaeumer.vscode-eslint",
    "dsznajder.es7-react-js-snippets",
    "xabikos.JavaScriptSnippets",
    "usernamehw.errorlens",
    "gruntfuggly.todo-tree",
    "eamodio.gitlens",
    "bradlc.vscode-tailwindcss"
  ],

  // ============================================================================
  // PERFORMANCE & MEMORY
  // ============================================================================

  "window.zoomLevel": 0,
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "editor.smoothScrolling": true,
  "editor.mouseWheelZoom": true,
  "editor.cursorSmoothCaretAnimation": "on",

  // ============================================================================
  // SECURITY & WORKSPACE
  // ============================================================================

  "security.workspace.trust.enabled": true,
  "security.workspace.trust.startupPrompt": "oncePerWorkspace",

  // ============================================================================
  // MISC
  // ============================================================================

  "telemetry.telemetryLevel": "off",
  "update.mode": "default",
  "workbench.startupEditor": "welcomePageInEmptyWorkbench",
  "workbench.sideBar.location": "left",
  "workbench.statusBar.visible": true,
  "workbench.activityBar.visible": true,
  "workbench.editor.tabSizing": "fit",

  // ============================================================================
  // CURSOR AI SPECIFIC
  // ============================================================================

  "cursor.general.onlyPlanForEdits": false,
  "cursor.chatGPT.shareConversationWithServer": false,
  "cursor.features.enableAgentic": true
}
