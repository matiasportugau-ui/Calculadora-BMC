# BMC Dashboard (Finanzas/Operaciones – Google Sheets)
# Ver docs/bmc-dashboard-modernization/GO-LIVE-DASHBOARD-CHECKLIST.md
BMC_SHEET_ID=
# Workbooks compartidos con la service account (opcional):
# Pagos Pendientes 2026: https://docs.google.com/spreadsheets/d/1AzHhalsZKGis_oJ6J06zQeOb6uMQCsliR82VrSKUUsI
BMC_PAGOS_SHEET_ID=
# Calendario de vencimientos: https://docs.google.com/spreadsheets/d/1bvnbYq7MTJRpa6xEHE5m-5JcGNI9oCFke3lsJj99tdk
BMC_CALENDARIO_SHEET_ID=
# 2.0 - Ventas: https://docs.google.com/spreadsheets/d/1KFNKWLQmBHj_v8BZJDzLklUtUPbNssbYEsWcmc0KPQA
BMC_VENTAS_SHEET_ID=
# Stock E-Commerce: https://docs.google.com/spreadsheets/d/1egtKJAGaATLmmsJkaa2LlCv3Ah4lmNoGMNm4l0rXJQw
BMC_STOCK_SHEET_ID=

# In-app bug reports — pestaña del CRM donde POST /api/bugs/report agrega filas (default BUG_REPORTS)
# BMC_BUG_REPORTS_TAB=BUG_REPORTS

# Wolfboard — Módulo operativo Admin 2.0 ↔ CRM (dashboard :3849)
# 2.0 - Administrador de Cotizaciones (libro fuente; H=consulta I=respuesta J=link K=enviado)
WOLFB_ADMIN_SHEET_ID=1Ie0KCpgWhrGaAKGAS1giLo7xpqblOUOIHEg1QbOQuu0
WOLFB_ADMIN_TAB=Admin.
# Primera fila de datos en Admin (H:K). Si encabezados ocupan fila 1 y datos fila 2 → 2
# WOLFB_ADMIN_FIRST_DATA_ROW=2
# Libro CRM separado (crm_automatizado 1N-4ky…). Vacío = usar BMC_SHEET_ID
# WOLFB_CRM_SHEET_ID=
# Tab operativa en CRM (mismo libro que BMC_SHEET_ID)
WOLFB_CRM_MAIN_TAB=CRM_Operativo
# "1" = no reescribir CRM G con bloque compuesto (solo AF/AH)
# WOLFB_SKIP_COMPOSED_G=
# Log JSON-lines de eventos Wolfboard en stdout (SYNC, ROW, BATCH, ENVIADOS)
# WOLFB_RITUAL_LOG=1
# Base URL API calculadora (ej. http://localhost:3001) para scripts que encadenen cotizar → presupuesto
# WOLFB_CALC_API_BASE=
# Tab destino para filas marcadas enviadas (K=TRUE)
WOLFB_CRM_ENVIADOS_TAB=Enviados
# Dual-write Lead → Admin Cotizaciones tab "Enviados" (opt-in; default off).
# Activar solo después de verificar manualmente que la tab "Enviados" en el workbook
# WOLFB_ADMIN_SHEET_ID usa el layout A:M de wolfboard.js (A=ID, B=Fecha, D=Tel, E=Cliente, …)
# WOLFB_ADMIN_COT_DUAL_WRITE=false
# WOLFB_ADMIN_COT_ENVIADOS_TAB=Enviados
# Poner "1" para modo lectura/dry-run (no escribe en Sheets)
WOLFB_DRY_RUN=

# Caché en memoria (TTL ms) para reducir lecturas Sheets API: nombres de pestañas y merge /api/ventas (todas las tabs).
# 0 = desactivar esa caché. Defaults: tab names 120000, ventas merge 90000.
# BMC_SHEETS_TAB_NAMES_TTL_MS=120000
# BMC_SHEETS_VENTAS_MERGE_TTL_MS=90000
# Reintentos en lecturas Sheets ante 429 / cuota: intentos (default 5) y backoff base ms (default 500). 1 = sin reintentos.
# BMC_SHEETS_READ_MAX_RETRIES=5
# BMC_SHEETS_READ_RETRY_BASE_MS=500
# MATRIZ de COSTOS y VENTAS 2026 — precios / CSV calculadora (PANELSIM: verificar cotizaciones)
# https://docs.google.com/spreadsheets/d/1oDMkBgWxX7cu7TpSvuO30tCTUWl68IBDhC4cQTP79Xo — compartir con la service account:
#   Lector = solo GET /api/actualizar-precios-calculadora; Editor = además POST /api/matriz/push-pricing-overrides desde la calculadora
# Default en código si omitís: 1oDMkBgWxX7cu7TpSvuO30tCTUWl68IBDhC4cQTP79Xo
# BMC_MATRIZ_SHEET_ID=
GOOGLE_APPLICATION_CREDENTIALS=docs/bmc-dashboard-modernization/service-account.json

# MercadoLibre OAuth (requerido para /auth/ml/* y /ml/*)
# Guía paso a paso: docs/ML-OAUTH-SETUP.md
ML_CLIENT_ID=742811153438318
ML_CLIENT_SECRET=
# Default si omitís: http://localhost:3001/auth/ml/callback — debe coincidir con la app en Developers
# ML_REDIRECT_URI_DEV=http://localhost:3001/auth/ml/callback
# Si ML exige https: ngrok → ML_REDIRECT_URI_DEV=https://xxx.ngrok-free.app/auth/ml/callback (misma URL en el portal ML)
# ML_USE_PROD_REDIRECT=false
# Sitio Mercado Libre (preguntas/búsquedas). Uruguay = MLU. Ver https://api.mercadolibre.com/sites
# ML_SITE_ID=MLU
# Encriptar .ml-tokens.enc (64 hex): node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# TOKEN_ENCRYPTION_KEY=
# .ml-tokens.enc es local y está en .gitignore — no commitear; OAuth por máquina / GCS en Cloud Run (docs/ML-OAUTH-SETUP.md).
# .ml-tokens.enc solo en tu máquina (.gitignore); no commitear — OAuth local o GCS en prod (ML_TOKEN_*).
# Cloud Run — persistencia de tokens (ver docs/ML-OAUTH-SETUP.md §7)
# ML_TOKEN_STORAGE=file
# ML_TOKEN_GCS_BUCKET=
# ML_TOKEN_GCS_OBJECT=ml-tokens.enc

# KB persistence en GCS (Cloud Run — auto-detectado via K_SERVICE)
# GCS_KB_BUCKET=bmc-cotizaciones   (default: reutiliza GCS_QUOTES_BUCKET)
# GCS_KB_OBJECT=kb/training-kb.json
# Webhook ML (opcional; POST /webhooks/ml)
# WEBHOOK_VERIFY_TOKEN=

# Cloud Run: URL base del servicio (para redirect_uri OAuth)
# npm run ml:cloud-run sincroniza estas vars al servicio.
# Ejemplo: PUBLIC_BASE_URL=https://panelin-calc-642127786762.us-central1.run.app
# Ver docs/ML-OAUTH-SETUP.md
PUBLIC_BASE_URL=

# Shopify (preguntas/cotizaciones – reemplazo Mercado Libre)
# Crear app en Partners, obtener Client ID/Secret y configurar redirect /auth/shopify/callback
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_SCOPES=read_products,write_products,read_orders,write_orders,read_customers,read_draft_orders,write_draft_orders
SHOPIFY_QUESTIONS_SHEET_TAB=Shopify_Preguntas

# Repo Sync (bmc-repo-sync-agent) — paths o URLs de repos a mantener actualizados
# bmc-dashboard-2.0: desarrollo y funcionamiento del dashboard
# bmc-development-team: equipo y artefactos
BMC_DASHBOARD_2_REPO=https://github.com/matiasportugau-ui/bmc-dashboard-2.0.git
BMC_DEVELOPMENT_TEAM_REPO=https://github.com/matiasportugau-ui/bmc-development-team.git

# PANELSIM — repo hermano conexion-cuentas-email-agentes-bmc (opcional).
# Si está definida, la skill panelsim-email-inbox usa esta ruta absoluta para npm run panelsim-update.
# Ejemplo macOS: BMC_EMAIL_INBOX_REPO=/Users/matias/Panelin calc loca/conexion-cuentas-email-agentes-bmc
BMC_EMAIL_INBOX_REPO=
# Snapshot IMAP para npm run email:ingest-snapshot (default: hermano data/snapshot-latest.json)
# BMC_EMAIL_SNAPSHOT_PATH=

# WhatsApp Business Cloud API (webhook automático → CRM)
# Configurar en Meta → WhatsApp → Configuration → Webhook
# Webhook (misma base que smoke:prod): https://panelin-calc-642127786762.us-central1.run.app/webhooks/whatsapp
# Checklist: docs/team/WHATSAPP-META-E2E.md — comprobación local: npm run wa:cloud-check
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Firma HMAC de webhooks Meta (POST /webhooks/whatsapp). Sin esto, el servidor omite verificación y registra warning.
WHATSAPP_APP_SECRET=

# Modo Transportista — Postgres (viajes, eventos, sesiones conductor, outbox WhatsApp)
# DATABASE_URL=postgres://user:pass@host:5432/db
# Evidencias firmadas GCS (opcional; si falta, usar POST /api/driver/evidence/upload-b64 en dev)
# TRANSPORTISTA_GCS_BUCKET=
# TRANSPORTISTA_DRIVER_TOKEN_TTL_HOURS=24
# TRANSPORTISTA_OUTBOX_INTERVAL_MS=15000
# TRANSPORTISTA_STRICT_POD=false

# Google Drive — carpeta compartida BMC (wolfboard, agente /cotizar/pdf, auto-archivo calculadora)
# La cuenta de servicio (GOOGLE_APPLICATION_CREDENTIALS) debe tener acceso Editor a la carpeta.
# DRIVE_QUOTE_FOLDER_ID=

# Google Cloud Storage — bucket para cotizaciones HTML persistentes (default: bmc-cotizaciones)
# Requiere allUsers:objectViewer + uniform-bucket-level-access. Comparte default con KB (server/lib/trainingKB.js).
# GCS_QUOTES_BUCKET=bmc-cotizaciones

# PDF generation — ruta a Chromium (server/routes/pdf.js). En Cloud Run apk chromium → /usr/bin/chromium-browser.
# Si se omite, Playwright usa su Chromium descargado.
# CHROMIUM_EXECUTABLE_PATH=

# AI providers — POST /api/crm/suggest-response (col AF respuesta inteligente)
# provider: claude | openai | gemini | grok  (default: claude)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# /api/crm/suggest-response routing.
#   true  (default) — delegate to server/lib/suggestResponse.js → callAgentOnce
#                     (full Panelin brain: KB retrieval, ML/WA channel overrides,
#                     canonical pricing block).
#   false           — legacy 1-line system prompt + manual provider chain.
# Runtime rollback knob: flip in Cloud Run env without redeploy.
SUGGEST_RESPONSE_USE_AGENT_CORE=true
# Modo voz fluido (POST /api/agent/voice/session) — OpenAI Realtime API (speech-to-speech, WebRTC)
# Requiere OPENAI_API_KEY. Modelo predeterminado si se omite:
# OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
# Calculadora — chat Panelin (POST /api/agent/chat); GET /api/agent/ai-options lista modelos permitidos
# Default si se omite: claude-opus-4-7 (server/config.js)
# ANTHROPIC_CHAT_MODEL=claude-opus-4-7
# GEMINI_CHAT_MODEL=gemini-2.0-flash
# GROK_CHAT_MODEL=grok-3-mini
GEMINI_API_KEY=
GROK_API_KEY=

# BMC Chat Express merge (GET /chat, /chat/api/*) — Gemini interpret + Sheets Admin
# Optional override for static UI path (default: server/static/bmc-chat/index.html)
# BMC_CHAT_HTML_PATH=
# Model for /chat/api/interpret (default: gemini-2.5-flash)
# BMC_GEMINI_MODEL=gemini-2.5-flash

# Vercel AI Gateway (multi-provider unificado) — preferido sobre las 4 keys de arriba.
# Ruta: /crm/suggest-response, /crm/parse-email, /crm/ingest-email, /agent/training-kb/generate-ml-overrides.
# Auth recomendada (OIDC, sin rotación manual): correr `vercel env pull` localmente y dejar
# que Vercel inyecte VERCEL_OIDC_TOKEN automáticamente. En Cloud Run o cualquier runtime
# fuera de Vercel, generar una API key estática desde la consola del gateway:
#   https://vercel.com/[team]/~/ai-gateway/api-keys
# Si AI_GATEWAY_API_KEY (o VERCEL_OIDC_TOKEN) está vacío, las rutas caen al chain SDK legacy.
AI_GATEWAY_API_KEY=

# Follow-up tracker (CLI npm run followup + GET/POST /api/followups) — JSON local por defecto .followup/store.json
# FOLLOWUP_STORE_PATH=/ruta/absoluta/followups.json

# CORS — orígenes permitidos para el API (coma-separados, scheme+host).
# Default: https://calculadora-bmc.vercel.app, http://localhost:5173, http://localhost:3001
# CORS_ORIGIN=https://calculadora-bmc.vercel.app,http://localhost:5173

# Cockpit CRM — GET/POST /api/crm/cockpit/* (quote-link, approval, mark-sent, send-approved, row)
# Mismo valor que API_KEY si lo usás. Sin esto, las rutas cockpit devuelven 503.
# API_AUTH_TOKEN=
# Alias legacy (mismo secreto que API_AUTH_TOKEN): cockpit y rutas autenticadas lo aceptan.
# API_KEY=
#
# Solo desarrollo local (API :3001 de confianza): omitir API_AUTH_TOKEN en rutas modo desarrollador
# (POST /api/agent/chat con devMode, KB, prompt editor). GET /capabilities expone panelin_relax_dev_auth.
# No usar en Cloud Run público ni producción.
# PANELIN_RELAX_DEV_AUTH=
#
# Team-assist simulacro (POST /api/team-assist/chat) — límite por IP (sin API_AUTH_TOKEN).
# Defaults: 20 solicitudes / 15 min. Ver server/routes/teamAssist.js.
# TEAM_ASSIST_RATE_MAX=20
# TEAM_ASSIST_RATE_WINDOW_MS=900000
#
# POST /api/crm/ingest-email (bridge IMAP → CRM): Bearer obligatorio.
# Si definís EMAIL_INGEST_TOKEN, el servidor acepta ese valor o API_AUTH_TOKEN (migración).
# Scripts: npm run email:ingest-snapshot envía EMAIL_INGEST_TOKEN si existe; si no, API_AUTH_TOKEN.
# Ver docs/team/panelsim/EMAIL-ADMINISTRATOR.md
EMAIL_INGEST_TOKEN=
#
# ── Chatwoot CE — shared operator inbox + in-app Email Agent ──────────────
# Self-hosted Chatwoot (off-stack). All optional: unset = feature dormant, app boots.
# Generate API token + ids inside the Chatwoot admin UI (Profile → Access Token; Account/Inbox ids in URLs).
# Full setup: docs/team/runbooks/chatwoot-email-agent-setup.md
CHATWOOT_API_BASE=
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_INBOX_ID=
# Shared secret the Chatwoot webhook must send (header X-Chatwoot-Webhook-Secret or ?secret=).
CHATWOOT_WEBHOOK_SECRET=
# Post auto-triage lead as a private note back into Chatwoot (default true).
CHATWOOT_POST_NOTE=true
# Post an AI draft reply as a private note (default false; the in-app agent owns drafting).
CHATWOOT_POST_DRAFT=false
# Optional override for server-to-server loopback base (default http://127.0.0.1:PORT).
SELF_BASE_URL=
# Chatwoot REST client HTTP timeout in ms (default 12000).
CHATWOOT_HTTP_TIMEOUT_MS=
#
# Casilla id (de config/accounts.json del repo de email) usada para responder
# cuando no se conoce la casilla receptora de una fila CRM. Default: bmc-ventas.
EMAIL_REPLY_DEFAULT_CASILLA=
#
# Gmail-API send (user-OAuth) — transporte de respuesta preferido ahora que el
# SMTP de Netuy está muerto (dominio migró a Cloudflare→Gmail). El refresh token
# lo emite `npm run gmail-auth` en el repo pipeline (scope gmail.send) sobre un
# cliente OAuth DEDICADO de Gmail (GMAIL_OAUTH_CLIENT_ID/SECRET), separado del de
# Drive para evitar revocación mutua del refresh token. Si los 3 están presentes,
# send-approved responde por Gmail; si no, cae al SMTP por casilla. GMAIL_SEND_FROM
# (opcional) debe ser un alias verificado "Send mail as" en la cuenta.
GMAIL_INGEST_REFRESH_TOKEN=
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_SEND_FROM=
# Allowlist de casillas BMC para el poller de Gmail (POST /api/email/poll-gmail,
# cron en email-ingest-scheduled.yml). Gmail `to:` es difuso, así que el filtro
# real es matching server-side sobre los headers de destinatario. Coma-separado.
GMAIL_INGEST_ADDRESSES=
#
# Panelin IA — Soft budget (POST /api/agent/chat). Default OFF.
# Activación gradual y semántica documentadas en docs/team/runbooks/PANELIN-IA-OPS.md §4.
# Identity = conversationId (estable por pestaña) o IP. Cualquiera de los caps que
# se exceda devuelve 429 + Retry-After. Cap vacío = inactivo (no se evalúa).
BUDGET_ENABLED=
BUDGET_TURNS_PER_MIN=
BUDGET_TURNS_PER_5MIN=
BUDGET_TURNS_PER_24H=
BUDGET_TOKENS_PER_24H=
#
# Panelin interno (GET /api/internal/panelin/*) — mismo Bearer que API_AUTH_TOKEN.
# Rol efectivo: header X-Panelin-Role = ventas | logistica | admin | director
# Si se omite el header: PANELIN_SERVICE_DEFAULT_ROLE (default en código: director)
# PANELIN_SERVICE_DEFAULT_ROLE=director

# Modo analítico — tendencias del entorno IA (Panelin Knowledge / events-log JSONL)
# GET /api/ai-analytics/trends?days=60 — en producción: mismo Bearer que API_AUTH_TOKEN
# Default de archivo: docs/team/knowledge/events-log.jsonl
# AI_KNOWLEDGE_EVENTS_LOG=

# KB Analytics — GET /api/agent/training-kb/analytics
# Log missed questions (kb_miss events) for human review in the Admin UI (opt-in, default off).
# When enabled + question matched zero KB entries, the question text is captured (first 200 chars).
# Privacidad: desactivado por defecto; marcar explícitamente =true en producción si se desea.
KB_ANALYTICS_LOG_MISS_QUESTION=false
# Window máximo de historial para métricas (default 90 días en código, max 365). En Analytics tab: user selecciona < este máximo.
KB_ANALYTICS_WINDOW_MAX_DAYS=90

# ── RAG v1 — Recuperación de cotizaciones históricas similares (pgvector) ──────
# DEFAULT OFF. Activar solo después de:
#   1. Correr migración: psql "$DATABASE_URL" -f migrations/0001_add_pgvector_and_quote_embeddings.sql
#   2. Correr batch:     node scripts/training/embedQuotes.js --limit 50 --dry-run  (verificar)
#                        node scripts/training/embedQuotes.js  (producción)
#   3. Verificar retrieve: ver docs/sprint-mayo/RAG-V1.md § Checklist de activación.
# RAG_ENABLED=false
# Número de cotizaciones similares a recuperar por turno (default 5, max 10).
# RAG_TOP_K=5
# Similitud mínima coseno (0-1) para incluir un caso (default 0.70).
# RAG_THRESHOLD=0.70

# ── API Node (server/config.js) — opcionales; defaults si se omiten ─────────
# APP_ENV=development
# PORT=3001
# ML_AUTH_BASE=https://auth.mercadolibre.com.uy
# ML_API_BASE=https://api.mercadolibre.com
# ML_REDIRECT_URI_PROD=
# ML_TOKEN_FILE=.ml-tokens.enc
# ML_HTTP_MAX_RETRIES=3
# ML_HTTP_TIMEOUT_MS=15000
# BMC_SHEET_SCHEMA=Master_Cotizaciones

# ── Frontend Vite (build-time) — Vercel / calculadora-bmc.vercel.app ─────────
# Se inyectan en el bundle con npm run build; en Vercel: Settings → Environment Variables.
# Guía: docs/VERCEL-CALCULADORA-SETUP.md
# VITE_API_URL=https://panelin-calc-642127786762.us-central1.run.app
# Chat BMC (iframe 💬). Default en código: Cloud Run bmc-chat (24/7).
# Override: VITE_BMC_CHAT_URL=…  |  Express local merge: VITE_BMC_CHAT_LOCAL=1
# VITE_BMC_CHAT_URL=https://bmc-chat-642127786762.us-central1.run.app
# VITE_BMC_CHAT_LOCAL=1
# Live design preview (OFF on production unless set): Vercel Preview enables automatically
# VITE_BMC_DESIGN_PREVIEW=1
# VITE_BASE=/
# SPA y API en el mismo Cloud Run (Dockerfile.bmc-dashboard): no hace falta VITE_API_URL si VITE_SAME_ORIGIN_API=1
# VITE_SAME_ORIGIN_API=1
# Nueva UI Administrador de Cotizaciones (/hub/cotizaciones).
# true → habilita la ruta nueva y redirige /hub/admin → /hub/cotizaciones; false (default) → módulo viejo.
# VITE_FEATURE_ADMIN_COT_V2=false
# Toggle Vendedor/Cliente en el toolbar del cotizador.
# Default oculto (UI no muestra el switch; modoVendedor=true persiste como modo por defecto).
# true → vuelve a mostrar el toggle.
# VITE_FEATURE_ROLE_TOGGLE=false
# Google OAuth Web client ID (público — GIS login + Drive en la SPA).
# MUST match GOOGLE_OAUTH_CLIENT_ID below and Cloud Run / Vercel production.
# Mismatch → 401 tokeninfo_aud_mismatch on POST /api/auth/google.
# Ver docs/team/runbooks/google-oauth-troubleshooting.md
VITE_GOOGLE_CLIENT_ID=642127786762-hbkkonaqp9vvfk2qa9sv5go4bd8u4sj3.apps.googleusercontent.com
# Vercel (CLI): npm run drive:vercel-env -- '<client-id>' — ver docs/VERCEL-CALCULADORA-SETUP.md
# Tras build: npm run verify:google-drive-dist (comprueba que el ID quedó en dist/)
# Mismo Bearer que API_AUTH_TOKEN: PricingEditor (MATRIZ) y Logística escriben desde el navegador. Solo builds internos.
# VITE_BMC_API_AUTH_TOKEN=

# ── Supabase (roadmap Fase 1+ — Auth · Postgres · pgvector · Storage) ────────
# Ver docs/team/OAUTH-SUPABASE-CHECKLIST.md — nunca commitear valores reales.
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
# Backend Cloud Run (validación JWT / jobs server-only):
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# ── Sketchfab 3D embeds (PanelFamilyShowcase) — opcional ──────────────────────
# ID del modelo Sketchfab por familia. Si está vacío, se muestra la imagen catálogo.
# Obtener el ID desde la URL del modelo: sketchfab.com/3d-models/<nombre>-<ID>
# Ejemplo: sketchfab.com/3d-models/isodec-eps-panel-abc123def456 → ID = abc123def456
# VITE_SKETCHFAB_ISODEC_EPS=
# VITE_SKETCHFAB_ISODEC_PIR=
# VITE_SKETCHFAB_ISOROOF_3G=
# VITE_SKETCHFAB_ISOROOF_PLUS=
# VITE_SKETCHFAB_ISOROOF_FOIL=
# VITE_SKETCHFAB_ISOROOF_COLONIAL=

# ── SMTP (digest diario magazine + WA Module Pro Settings magic-link auth) ──
# Gmail: contraseña de aplicación (2FA). Mismo SMTP se usa para:
#   - npm run magazine:daily:send  → docs/team/orientation/MAGAZINE-DAILY-EMAIL.md
#   - WA Module Pro Settings (magic-link operator login) → docs/wa-cockpit/OPERATOR-GUIDE.md
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.account@gmail.com
SMTP_PASS=your-app-password
# Magazine email
# MAG_DAILY_EMAIL_FROM=matias.portugau@gmail.com
# MAG_DAILY_EMAIL_TO=matias.portugau@gmail.com
# MAG_DAILY_ATTACH_MAGAZINE=1

# ── WA Module Pro Settings — Operator Auth (magic-link + JWT) ────────────────
# Magic-link sign-in para operadores del WA Cockpit. Ver:
#   docs/wa-cockpit/OPERATOR-GUIDE.md  ·  docs/wa-cockpit/CONFIG-REFERENCE.md
# Bootstrap del primer Owner sin email: scripts/wa-admin.mjs operator add --role owner
# WA_JWT_SECRET firma sesiones; rotar invalida todas las sesiones operador activas.
WA_AUTH_EMAIL_FROM=Panelin WA <noreply@panelin.uy>
WA_JWT_SECRET=change-me-please-32-chars-minimum

# ── WA Cockpit (F2-F5) — ver docs/wa-cockpit/README.md ───────────────────────
# WA Cockpit captura conversaciones de WhatsApp Web vía la extensión Chrome
# (repo separado: ../calculadora-bmc-wa-extension/) y las almacena en Postgres
# `wa_*` (mismo DATABASE_URL que Transportista). Migraciones: npm run wa:migrate
#
# Enricher worker (F2): genera 3 sugerencias AI por cada mensaje inbound.
# WA_ENRICHER_ENABLED=false               # true para activar el worker en Cloud Run
# WA_ENRICHER_INTERVAL_MS=8000            # cada cuánto polea wa_messages sin enriched_at
# WA_ENRICHER_BATCH_SIZE=5                # mensajes por iteración

# Omni Core — cross-channel inbox (shadow writes default OFF)
# OMNI_WA_SHADOW_WRITE=0
# OMNI_ML_SHADOW_WRITE=0
# OMNI_EMAIL_SHADOW_WRITE=0
# OMNI_EVENT_BUS_ENABLED=0
# OMNI_AI_ORCHESTRATOR_ENABLED=0
# OMNI_AUTOMATION_ENABLED=0
# WA flip (ADR-009): ON => Omni event bus is the single WA path; legacy in-memory
# map + 5-min timer + duplicate AI call disabled, CRM ingest + auto-learn run as a
# durable wa_crm_sync job. Default OFF ships dormant. Needs EVENT_BUS + AI_ORCHESTRATOR ON.
# OMNI_WA_CANONICAL=0
# Inactivity window (ms) before a wa_crm_sync job runs (burst debounce). Default 60000.
# OMNI_WA_CRM_SYNC_DELAY_MS=60000
# ON => WA cockpit reads from omni_* instead of wa_* (read-model convergence). Default OFF.
# OMNI_WA_READS=0
# OMNI_DEALS_SHEETS_AUTHORITY=1
# OMNI_AI_DAILY_BUDGET_USD=50
# OMNI_AI_WORKER_INTERVAL_MS=5000
# OMNI_AI_WORKER_BATCH_SIZE=5
# OTEL_ENABLED=0
# OMNI_OTEL_DEBUG=0

# AI Assistant control plane — master switch. Comma-separated allowlist of assistant
# keys allowed to GENERATE AI responses; anything else returns 503 assistant_disabled
# on its generation route (inbound ingest/webhooks stay open). Keys: canales, panelin,
# email, wa, ml, wolfboard. Default (unset) = canales-only. See server/lib/assistantRegistry.js.
# ASSISTANTS_ACTIVE=canales

# Centralized AI brain (self-evolving lessons) injected into the Panelin system prompt.
# Default OFF: setting VITE_FEATURE_BRAIN=true is customer-facing. Source of truth is the
# GCS object below (shared with the sheet-quote pipeline); BRAIN_LOCAL_PATH overrides for dev.
# VITE_FEATURE_BRAIN=false
# BRAIN_GCS_BUCKET=bmc-ml-tokens
# BRAIN_GCS_OBJECT=bmc-brain/lessons.json
# BRAIN_LOCAL_PATH=                        # absolute path to a local lessons.json (dev only)
# BRAIN_INJECT_CAP=10                      # max lessons injected per prompt
# BRAIN_REFRESH_MS=300000                  # GCS cache refresh interval (min 60000)
# VITE_OMNI_INBOX surfaces the Chatwoot-style Omni Inbox as a view in /hub/canales.
# Prod defaults to 1 (set in .github/workflows/deploy-vercel.yml); set the repo Variable
# VITE_OMNI_INBOX=0 as a kill switch. For local dev, set VITE_OMNI_INBOX=1 in your .env.
# VITE_OMNI_INBOX=1
# VITE_OMNI_DEALS=0
#
# Outbound rate-limit (F4): mensajes/min por (chat_id, operator_id).
# WA_OUTBOUND_RATE_LIMIT=6
#
# Purge TTL (F5): npm run wa:purge-old borra wa_messages.text con ts > N días.
# WA_TTL_DAYS=180

# ── npm predev / prebuild (disco) — ver docs/team/orientation/DISK-SPACE-RECOVERY-AGENT.md
# BMC_DISK_PRECHECK_SKIP=1
# BMC_DISK_MIN_FREE_MIB=1024
# BMC_DISK_PRECHECK_MODE=warn

# ─── TraKtiMe — time tracking + invoicing (mounted at /hub/traktime) ──────
# Reuses DATABASE_URL above. Apply migrations: npm run traktime:migrate.
# Optional Google Sheets workbook ID for the nightly operator mirror (5 tabs:
# Clients, Projects, Entries, Invoices, Audit). When unset, the mirror worker
# is a no-op and the API still serves /hub/traktime end-to-end.
# TRAKTIME_SHEET_ID=
# TRAKTIME_MIRROR_TZ=America/Montevideo
# TRAKTIME_MIRROR_ENABLED=true
# TRAKTIME_INVOICE_ISSUER_NAME=METALOG SAS — BMC Uruguay
# TRAKTIME_INVOICE_ISSUER_RUT=21XXXXXXXXXX
# TRAKTIME_INVOICE_ISSUER_ADDRESS=Direccion pendiente, Montevideo, Uruguay
# TRAKTIME_INVOICE_GCS_BUCKET=bmc-cotizaciones
# Jornada/hours report: gap above this many minutes is labeled "pausa"
# instead of "coordinacion" (default 30; overridable per-request via ?pausa_min).
# TRAKTIME_PAUSA_THRESHOLD_MIN=30
# ActivityWatch (passive OS observation) — STRICTLY OPT-IN, OFF by default.
# Only works where the API is co-located with a local aw-server (dev/self-host
# on the operator's machine); leave disabled in Cloud Run. See
# docs/team/traktime/ACTIVITYWATCH-OPTIN.md.
# TRAKTIME_AW_ENABLED=0
# TRAKTIME_AW_BASE_URL=http://localhost:5600
# ─── Comprador identity (master plan, Phase A+) ────────────────────────────
# JWT signing secret for end-user access tokens (>= 32 chars).
# MUST be distinct from WA_JWT_SECRET (cross-system token substitution guard).
# Server hard-fails at startup in production if empty or equal to WA_JWT_SECRET.
# Generate: openssl rand -base64 48
IDENTITY_JWT_SECRET=replace-me-with-openssl-rand-base64-48-output
# AES-256-GCM key encrypting TOTP secrets in identity.mfa_secrets (32 bytes hex).
# Intentionally separate from IDENTITY_JWT_SECRET so JWT secret rotation does
# not silently re-key every enrolled MFA secret. Required when /api/auth/mfa/*
# is in use; throws on missing/wrong-length in production.
# Generate: openssl rand -hex 32
MFA_KEK_HEX=replace-me-with-openssl-rand-hex-32-output
# Cookie domain for the bmc_sess refresh token (prod: ".calculadora-bmc.vercel.app").
IDENTITY_COOKIE_DOMAIN=
# Override cookie name (default: bmc_sess).
IDENTITY_COOKIE_NAME=bmc_sess
# Google OAuth Web client ID — backend audience check (tokeninfo / verifyIdToken).
# MUST match VITE_GOOGLE_CLIENT_ID above (same OAuth Web client in GCP chatbot-bmc-live).
GOOGLE_OAUTH_CLIENT_ID=642127786762-hbkkonaqp9vvfk2qa9sv5go4bd8u4sj3.apps.googleusercontent.com
# Comma-separated emails seeded as superadmin on first Google login.
INTERNAL_SUPERADMIN_EMAILS=

# ─── Sheets sync — opt-in admin sync to «Base de datos cotis de clientes» ──
SHEETS_CLIENT_QUOTES_ENABLED=false
SHEETS_CLIENT_QUOTES_TAB=Base de datos cotis de clientes

# ─── Tasks Sync — HMAC verification for external task sync payloads ─────────
# Shared secret for verifying HMAC signatures on incoming task sync webhooks.
# Used by server/routes/tasksSync.js to validate payload authenticity.
# Cloud Scheduler sends this raw value as the X-Sync-Signature header.
# Generate: openssl rand -base64 32
SYNC_HMAC_SECRET=

# ─── Frontend bounce target — used by OAuth callbacks running on the backend ─
# Vite SPA host. Defaults to https://calculadora-bmc.vercel.app when unset.
# Override on preview deploys: FRONTEND_BASE_URL=https://<preview>.vercel.app
# Override in local dev:        FRONTEND_BASE_URL=http://localhost:5173
FRONTEND_BASE_URL=

# ─── Tasks OAuth — Google Tasks API client (separate from identity login) ───
# Web-application OAuth 2.0 client from GCP Console with PKCE flow.
# Redirect URI must be: https://panelin-calc.run.app/auth/tasks/callback
# Provision per docs/hub-tasks-module/OPERATOR-CHECKLIST.md (Step 1).
GOOGLE_TASKS_CLIENT_ID=
GOOGLE_TASKS_CLIENT_SECRET=
# Override redirect URI for Tasks OAuth (defaults to auto-detected base URL + /api/tasks/oauth/callback)
# GOOGLE_TASKS_REDIRECT_URI=

# ─── Tasks Token Encryption — PGP symmetric key for oauth_tokens at rest ────
# 32-byte base64 key used by pgp_sym_encrypt/pgp_sym_decrypt in Supabase.
# Generate: openssl rand -base64 32  (then store in Secret Manager per checklist).
SUPABASE_PGP_ENCRYPT_KEY=

# ─── Market Intelligence — competitor price monitoring ──────────────────────
# Alert thresholds (percentage change triggers)
ALERT_WARN_PCT=5
ALERT_CRITICAL_PCT=15
# Number of consecutive offline ETL runs to trigger a CRITICAL alert
ALERT_CRITICAL_OFFLINE_RUNS=2
# Email sender/recipient for alert notifications (uses existing SMTP_* config)
ALERT_EMAIL_FROM=alertas@bmc.uy
ALERT_EMAIL_TO=matias@bmc.uy

# ─── Activity Log — session tracking ───────────────────────────────────────
# Hours after last_active_at before a session is auto-closed (default 24)
# ACTIVITY_LOG_ORPHAN_TTL_HOURS=24

# ─── Todoist — Project Status Dashboard (/hub/proyecto) ────────────────────
# Token personal: todoist.com/app/settings/integrations/developer → API token
TODOIST_API_TOKEN=
# ID del proyecto BMC en Todoist (ya creado con las secciones y tareas del repo)
TODOIST_BMC_PROJECT_ID=6grV9QhFpvPJ79hx

# Feature Flags (Vercel / local)
# VITE_FEATURE_ADMIN_COT_V2=true
# VITE_FEATURE_TUTORIAL_MODE=true   # Interactive in-app tutorial (Modo Tutorial) for sales team onboarding
# VITE_FEATURE_EMAIL_AGENT=true     # Right-side "Asistente de Correos BMC" panel (needs CHATWOOT_* + canales:write). Default off.


# ML Manager connector (hub/ml-manager)
VITE_ML_CONNECTOR_URL=http://localhost:3001
VITE_ML_CONNECTOR_API_KEY=

# API Health Board (npm run health) — dev pass para superficies protegidas.
# Bearer JWT de identity con grant canales:read (idealmente vía Doppler, NO commitear).
# Sin token, las superficies protegidas (p. ej. /api/omni/admin/overview) se
# reportan AUTH (montadas + gated, sano); con token se reportan OK + payload.
#   doppler run -- npm run health -- --env=prod
BMC_HEALTH_TOKEN=
# Entorno por defecto del board (local|prod). Override: --env= / --base=
BMC_HEALTH_ENV=prod
