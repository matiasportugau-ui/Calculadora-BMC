PORT=3001
APP_ENV=development
LOG_LEVEL=info
PUBLIC_BASE_URL=http://localhost:3001

# MercadoLibre app credentials (BMCCHAT client id fixed)
ML_CLIENT_ID=742811153438318
ML_CLIENT_SECRET=REPLACE_ME

# Redirects must exist in MercadoLibre DevCenter
ML_REDIRECT_URI_DEV=http://localhost:3001/auth/ml/callback
ML_REDIRECT_URI_PROD=https://your-domain.com/auth/ml/callback
ML_USE_PROD_REDIRECT=false

ML_AUTH_BASE=https://auth.mercadolibre.com.uy
ML_API_BASE=https://api.mercadolibre.com

# Token storage
ML_TOKEN_FILE=.ml-tokens.enc

# Optional AES-256-GCM key (64 hex chars). Strongly recommended outside local dev.
# TOKEN_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Optional webhook shared token
WEBHOOK_VERIFY_TOKEN=

# HTTP behavior
ML_HTTP_MAX_RETRIES=3
ML_HTTP_TIMEOUT_MS=15000
