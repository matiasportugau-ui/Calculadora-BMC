  "description": "Calculadora de cotización de paneles de aislamiento — BMC Uruguay (METALOG SAS)",
  "private": true,
  "type": "module",
  "main": "src/components/PanelinCalculadoraV3.jsx",
  "scripts": {
    "dev": "vite",
    "dev:api": "node --watch server/index.js",
