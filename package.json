    "html2pdf.js": "^0.14.0",
    "lucide-react": "^0.263.1",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.1.0",
    "easymidi": "^2.1.1",
    "eslint": "^9.39.3",
