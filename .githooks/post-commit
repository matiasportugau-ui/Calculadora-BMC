#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

GIT_DIR_ABS="$(git rev-parse --git-dir)"
if [ -d "$GIT_DIR_ABS/rebase-merge" ] || [ -d "$GIT_DIR_ABS/rebase-apply" ]; then
  exit 0
fi
if git rev-parse -q --verify REBASE_HEAD >/dev/null 2>&1; then
  exit 0
fi

if [ "${SKIP_AUTOTRACE:-}" = "1" ]; then
  exit 0
fi

# ── Skip self-loop: do not autotrace dev-trace commits ───────────────────────
COMMIT_MSG=$(git log -1 --pretty=%B HEAD 2>/dev/null || true)
if [[ "$COMMIT_MSG" == "docs: dev-trace"* ]] || [[ "$COMMIT_MSG" == "docs: autotrace"* ]] || [[ "$COMMIT_MSG" == "autolog:"* ]]; then
  exit 0
fi

if command -v python3 >/dev/null 2>&1; then
  python3 tools/release-traceability/scripts/generate_commit_doc.py || true
  python3 tools/release-traceability/scripts/rebuild_changelog.py || true
else
  echo "[WARN] python3 no disponible; se omite AUTOTRACE"
fi

# ── Accessible Base KB — compile project knowledge for AI context ─────────────
if command -v node >/dev/null 2>&1; then
  node scripts/build-accessible-base.mjs --quiet || true
fi
