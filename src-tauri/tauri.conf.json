{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BMC TraKtiMe",
  "version": "0.1.0",
  "identifier": "uy.com.bmc.traktime",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "timer",
        "title": "TraKtiMe",
        "url": "https://calculadora-bmc.vercel.app/hub/traktime?tkDetached=1",
        "width": 360,
        "height": 260,
        "minWidth": 280,
        "minHeight": 200,
        "resizable": true,
        "decorations": true,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
