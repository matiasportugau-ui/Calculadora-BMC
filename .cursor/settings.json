{
  "plugins": {
    "meta-quest-agentic-tools": {
      "enabled": true
    },
    "supabase": {
      "enabled": true
    },
    "vercel": {
      "enabled": true
    }
  },
  "cursor": {
    "rules": {
      "alwaysApply": [
        "workspace-autostart-on-open",
        "00-bootstrap-state"
      ]
    }
  },
  "editor": {
    "formatOnSave": true,
    "codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  }
}
